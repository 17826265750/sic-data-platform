# =====================================
# SiC Data Platform Configuration
# =====================================
# Copy this file to .env and update values

# Database Configuration (SQLite)
# Database file will be stored in ./data/sic_platform.db
# DATABASE_URL=sqlite+aiosqlite:///./data/sic_platform.db
# DATABASE_SYNC_URL=sqlite:///./data/sic_platform.db

# Redis Configuration (no password by default)
# REDIS_PASSWORD=optional_redis_password

# Application Settings
DEBUG=false
CORS_ORIGINS=http://localhost:3000,http://localhost

# Celery Worker Configuration
CELERY_CONCURRENCY=2

# File Upload Settings (in bytes)
# MAX_UPLOAD_SIZE=52428800

# Optional: Custom storage paths
# UPLOAD_DIR=/app/storage/uploads
# RESULT_DIR=/app/storage/results