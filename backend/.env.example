# Application
APP_NAME=sic-data-platform
APP_VERSION=1.0.0
DEBUG=true

# Server
HOST=0.0.0.0
PORT=8000

# Database (SQLite)
DATABASE_URL=sqlite+aiosqlite:///./data/sic_platform.db
DATABASE_SYNC_URL=sqlite:///./data/sic_platform.db

# Redis
REDIS_URL=redis://redis:6379/0

# Storage
UPLOAD_DIR=/app/storage/uploads
RESULT_DIR=/app/storage/results
MAX_UPLOAD_SIZE=52428800  # 50MB

# Celery
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# Chinese Font Path (for matplotlib in Docker)
CHINESE_FONT_PATH=/usr/share/fonts/truetype/wqy/wqy-microhei.ttc

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173